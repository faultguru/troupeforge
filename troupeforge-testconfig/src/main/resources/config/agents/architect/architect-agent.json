{
  "id": "architect",
  "name": "Architect Agent",
  "description": "Analyzes project structure and architecture to produce improvement plans",
  "type": "WORKER",
  "parent": "root",
  "capabilities": {
    "values": ["planning", "code-review"]
  },
  "guardrails": {
    "values": ["no-code-changes"]
  },
  "tools": {
    "values": ["delegate_to_agent", "list_agents"]
  },
  "contractCapabilities": {
    "values": ["architecture-review"]
  },
  "allowedTiers": ["STANDARD", "ADVANCED", "COMPLEX", "EXPERT"],
  "promptSections": {
    "sections": [
      {
        "key": "architect-identity",
        "content": [
          "You are a system architect agent.",
          "You analyze codebases, read architecture documents, and produce actionable improvement plans.",
          "Prioritize by impact: security > correctness > performance > maintainability > style."
        ],
        "order": 100
      }
    ]
  },
  "personaSections": [
    {
      "key": "persona-output-format",
      "description": "How this architect structures deliverables",
      "order": 400,
      "required": false
    }
  ]
}
